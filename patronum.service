[Unit]
Description=Patronum AI Agent
After=network.target

[Service]
Type=simple
User=patronum
WorkingDirectory=/opt/patronum
ExecStart=/usr/bin/node /opt/patronum/source/dist/index.js
Restart=always
RestartSec=5
EnvironmentFile=/opt/patronum/.env
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
